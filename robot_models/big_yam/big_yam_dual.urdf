    </visual>
  </link>
  <joint name="left_joint3" type="revolute">
    <origin xyz="0 -0.3787 0.068" rpy="0 0 0"/>
    <parent link="left_link_2"/><child link="left_link_3"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="10" lower="-0.1" upper="3.66519"/>
  </joint>

  <link name="left_link_4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>

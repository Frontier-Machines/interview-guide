      <material name="silver"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
  </link>
  <joint name="left_joint4" type="revolute">
    <origin xyz="0 0.38198 0" rpy="0 0 0"/>
    <parent link="left_link_3"/><child link="left_link_4"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="10" lower="-1.5708" upper="1.5708"/>
  </joint>

  <link name="left_link_5">

<?xml version="1.0" encoding="utf-8"?>
<robot name="big-yam-dual">

  <!-- World base -->
  <link name="world"/>

  <!-- ==================== LEFT ARM ==================== -->
  <link name="left_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry><mesh filename="assets/joint1.STL"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
  </link>
  <joint name="left_base_joint" type="fixed">
    <origin xyz="0 0.25 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="left_base_link"/>
  </joint>

  <link name="left_link_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="assets/joint2_link.STL"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
  </link>
  <joint name="left_joint1" type="revolute">
    <origin xyz="0 0 0.07735" rpy="0 0 -1.5708"/>
    <parent link="left_base_link"/><child link="left_link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-2.61799" upper="3.05433"/>
  </joint>

  <link name="left_link_2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="assets/joint3_link.STL"/></geometry>
      <material name="silver"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
  </link>
  <joint name="left_joint2" type="revolute">
    <origin xyz="0 0.021912 0.053202" rpy="0 0 0"/>
    <parent link="left_link_1"/><child link="left_link_2"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="10" lower="-3.66" upper="0.1"/>
  </joint>

  <link name="left_link_3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
